<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Horizons — Voyagez autrement</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --night: #090e1a;
      --navy: #0d1b35;
      --blue: #1a3a6b;
      --sky: #2e6fc4;
      --ice: #a8d4f5;
      --white: #f0f4ff;
      --gold: #f0c060;
      --silver: #8899bb;
      --glass: rgba(255,255,255,0.05);
      --glass-border: rgba(255,255,255,0.10);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Outfit', sans-serif; background: var(--night); color: var(--white); overflow-x: hidden; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--night); }
    ::-webkit-scrollbar-thumb { background: var(--sky); border-radius: 2px; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5vw; height: 72px;
      background: rgba(9,14,26,0.88); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
      animation: slideDown .7s ease both;
    }
    @keyframes slideDown { from{transform:translateY(-100%);opacity:0} to{transform:translateY(0);opacity:1} }

    .logo { text-decoration: none; display: flex; align-items: center; gap: .7rem; }
    .logo-svg { width: 38px; height: 38px; }
    .logo-text { font-family:'Cormorant Garamond',serif; font-size:1.55rem; font-weight:600; color:var(--white); letter-spacing:.04em; }
    .logo-text span { color:var(--gold); font-style:italic; }

    .nav-center { display: flex; gap: .4rem; align-items: center; }
    .nav-item { position: relative; }
    .nav-btn {
      background: none; border: none; cursor: pointer;
      color: rgba(240,244,255,.7); font-family:'Outfit',sans-serif;
      font-size:.9rem; font-weight:500; padding:.5rem 1rem; border-radius:.5rem;
      display:flex; align-items:center; gap:.4rem; transition: color .25s, background .25s;
    }
    .nav-btn svg { width:11px; height:11px; transition:transform .3s; }
    .nav-btn:hover, .nav-item:hover .nav-btn { color:var(--white); background:var(--glass); }
    .nav-item:hover .nav-btn svg { transform:rotate(180deg); }

    .dropdown {
      position: absolute; top: calc(100% + 10px); left: 50%;
      transform: translateX(-50%) translateY(8px);
      opacity: 0; pointer-events: none;
      transition: opacity .25s, transform .25s;
      min-width: 440px;
      background: rgba(10,20,42,0.97); backdrop-filter:blur(24px);
      border: 1px solid var(--glass-border); border-radius:1.2rem; padding:1.2rem;
      display: grid; gap: .5rem;
    }
    .dropdown.wide { min-width: 520px; grid-template-columns:1fr 1fr; }
    .nav-item:hover .dropdown { opacity:1; pointer-events:all; transform:translateX(-50%) translateY(0); }

    .drop-item {
      display:flex; align-items:center; gap:.9rem;
      padding:.85rem 1rem; border-radius:.8rem;
      text-decoration:none; color:var(--white); transition:background .2s;
    }
    .drop-item:hover { background:var(--glass); }
    .drop-icon { font-size:1.5rem; flex-shrink:0; width:38px; text-align:center; }
    .drop-title { font-weight:500; font-size:.9rem; }
    .drop-sub { font-size:.76rem; color:var(--silver); margin-top:.1rem; }

    .nav-link {
      text-decoration:none; color:rgba(240,244,255,.7); font-size:.9rem; font-weight:500;
      padding:.5rem 1rem; border-radius:.5rem; transition:color .25s, background .25s;
    }
    .nav-link:hover { color:var(--white); background:var(--glass); }
    .nav-cta {
      background:var(--sky); color:var(--white); border:none; cursor:pointer;
      font-family:'Outfit',sans-serif; font-size:.9rem; font-weight:600;
      padding:.55rem 1.4rem; border-radius:2rem; text-decoration:none;
      transition: background .25s, transform .2s, box-shadow .2s;
    }
    .nav-cta:hover { background:var(--gold); color:var(--night); transform:translateY(-1px); box-shadow:0 6px 20px rgba(240,192,96,.3); }

    /* HERO */
    .hero {
      min-height: 100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;
      text-align:center; padding:8rem 5vw 5rem; position:relative; overflow:hidden;
    }
    .stars { position:absolute; inset:0; overflow:hidden; z-index:0; }
    .star { position:absolute; background:white; border-radius:50%; animation:twinkle var(--d,3s) ease-in-out infinite alternate; }
    @keyframes twinkle { from{opacity:.08} to{opacity:.65} }

    .globe-deco {
      position:absolute; right:-100px; top:50%; transform:translateY(-50%);
      width:550px; height:550px; border-radius:50%;
      background:radial-gradient(ellipse at 35% 35%, rgba(46,111,196,.2), rgba(9,14,26,0) 65%);
      border:1px solid rgba(46,111,196,.12); pointer-events:none;
    }
    .globe-deco::before { content:''; position:absolute; inset:35px; border-radius:50%; border:1px solid rgba(46,111,196,.07); }

    .hero-content { position:relative; z-index:1; max-width:820px; }
    .hero-badge {
      display:inline-flex; align-items:center; gap:.5rem;
      background:rgba(46,111,196,.12); border:1px solid rgba(46,111,196,.28);
      color:var(--ice); font-size:.78rem; font-weight:500;
      letter-spacing:.08em; text-transform:uppercase;
      padding:.4rem 1.1rem; border-radius:2rem; margin-bottom:2rem;
      animation:fadeUp .7s ease .2s both;
    }
    .hero-badge::before { content:''; width:6px; height:6px; background:var(--ice); border-radius:50%; animation:pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.3;transform:scale(.5)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

    .hero h1 {
      font-family:'Cormorant Garamond',serif; font-size:clamp(3rem,7vw,6rem);
      font-weight:300; line-height:1.05; letter-spacing:-.02em; margin-bottom:1.5rem;
      animation:fadeUp .7s ease .35s both;
    }
    .hero h1 strong { font-weight:600; color:var(--gold); font-style:italic; }
    .hero-sub { font-size:1.05rem; color:var(--silver); line-height:1.7; max-width:520px; margin:0 auto 2.5rem; animation:fadeUp .7s ease .5s both; }
    .hero-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; animation:fadeUp .7s ease .65s both; }
    .btn-primary { background:var(--sky); color:white; padding:.9rem 2.2rem; border-radius:3rem; text-decoration:none; font-weight:600; font-size:1rem; transition:all .3s; }
    .btn-primary:hover { background:var(--gold); color:var(--night); transform:translateY(-2px); box-shadow:0 10px 30px rgba(240,192,96,.2); }
    .btn-ghost { background:var(--glass); color:var(--white); border:1px solid var(--glass-border); padding:.9rem 2.2rem; border-radius:3rem; text-decoration:none; font-weight:500; font-size:1rem; backdrop-filter:blur(8px); transition:all .3s; }
    .btn-ghost:hover { background:rgba(255,255,255,.1); transform:translateY(-2px); }

    .hero-stats { display:flex; justify-content:center; gap:4rem; margin-top:4rem; padding-top:3rem; border-top:1px solid var(--glass-border); animation:fadeUp .7s ease .8s both; }
    .stat-n { font-family:'Cormorant Garamond',serif; font-size:2.4rem; font-weight:600; color:var(--gold); }
    .stat-l { font-size:.78rem; color:var(--silver); letter-spacing:.06em; margin-top:.1rem; }

    .float-cards { position:absolute; bottom:2.5rem; display:flex; gap:1rem; z-index:1; animation:fadeUp .7s ease 1s both; flex-wrap:wrap; justify-content:center; }
    .float-card { background:rgba(13,27,53,.88); border:1px solid var(--glass-border); backdrop-filter:blur(16px); border-radius:1rem; padding:.75rem 1.1rem; display:flex; align-items:center; gap:.8rem; font-size:.83rem; }
    .float-flag { font-size:1.3rem; }
    .float-name { font-weight:600; }
    .float-price { color:var(--gold); font-size:.76rem; margin-top:.1rem; }

    /* SECTIONS */
    section { padding: 6rem 5vw; }
    .s-tag { color:var(--sky); font-size:.76rem; letter-spacing:.12em; text-transform:uppercase; font-weight:600; margin-bottom:.8rem; }
    .s-title { font-family:'Cormorant Garamond',serif; font-size:clamp(1.9rem,3.5vw,3rem); font-weight:300; line-height:1.15; letter-spacing:-.01em; }
    .s-title em { font-style:italic; color:var(--gold); font-weight:600; }
    .s-sub { color:var(--silver); line-height:1.7; margin-top:.7rem; max-width:520px; }
    .s-head { margin-bottom:3.5rem; }
    .s-head.center { text-align:center; }
    .s-head.center .s-sub { margin-inline:auto; }

    /* DESTINATIONS */
    #destinations { background:var(--navy); }
    .dest-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .dest-card { position:relative; border-radius:1.2rem; overflow:hidden; cursor:pointer; min-height:240px; display:flex; align-items:flex-end; transition:transform .4s; }
    .dest-card:hover { transform:translateY(-5px); }
    .dest-card.large { grid-column:span 2; min-height:350px; }
    .dest-bg { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:5.5rem; transition:transform .5s; }
    .dest-card:hover .dest-bg { transform:scale(1.06); }
    .d1{background:linear-gradient(145deg,#0a1628,#1a3a6b)} .d2{background:linear-gradient(145deg,#0d2137,#1d5c3a)} .d3{background:linear-gradient(145deg,#2d1b00,#7a4200)} .d4{background:linear-gradient(145deg,#1a0030,#4b0082)} .d5{background:linear-gradient(145deg,#001a40,#005bb5)} .d6{background:linear-gradient(145deg,#0a2e0a,#1e6b1e)}
    .dest-info { position:relative; z-index:1; width:100%; padding:1.2rem 1.4rem; background:linear-gradient(to top,rgba(0,0,0,.85),transparent); }
    .dest-region { font-size:.7rem; color:rgba(255,255,255,.5); letter-spacing:.1em; text-transform:uppercase; }
    .dest-name { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:600; }
    .dest-tags { display:flex; gap:.4rem; margin-top:.4rem; flex-wrap:wrap; }
    .dest-tag { font-size:.68rem; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.14); padding:.2rem .6rem; border-radius:2rem; }
    .dest-cta { display:inline-block; margin-top:.8rem; background:var(--sky); color:white; font-size:.76rem; font-weight:600; padding:.32rem .85rem; border-radius:2rem; text-decoration:none; transition:background .3s; }
    .dest-cta:hover { background:var(--gold); color:var(--night); }

    /* OFFRES */
    #offres { background:var(--night); }
    .offres-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:1.1rem; }
    .offre-card { background:var(--glass); border:1px solid var(--glass-border); border-radius:1.2rem; padding:1.8rem; transition:border-color .3s,transform .3s,box-shadow .3s; position:relative; overflow:hidden; }
    .offre-card:hover { border-color:rgba(46,111,196,.45); transform:translateY(-4px); box-shadow:0 16px 48px rgba(9,14,26,.5); }
    .offre-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--sky),var(--gold)); opacity:0; transition:opacity .3s; }
    .offre-card:hover::before { opacity:1; }
    .offre-badge { display:inline-block; background:rgba(240,192,96,.12); color:var(--gold); border:1px solid rgba(240,192,96,.28); font-size:.68rem; font-weight:600; letter-spacing:.08em; text-transform:uppercase; padding:.23rem .7rem; border-radius:2rem; margin-bottom:1.1rem; }
    .offre-emoji { font-size:2.1rem; margin-bottom:.8rem; display:block; }
    .offre-title { font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:600; margin-bottom:.5rem; }
    .offre-desc { font-size:.86rem; color:var(--silver); line-height:1.6; margin-bottom:1.1rem; }
    .offre-price { display:flex; align-items:baseline; gap:.45rem; margin-bottom:1.1rem; }
    .offre-from { font-size:.76rem; color:var(--silver); }
    .offre-amount { font-family:'Cormorant Garamond',serif; font-size:1.9rem; font-weight:600; color:var(--gold); }
    .offre-unit { font-size:.78rem; color:var(--silver); }
    .offre-btn { display:block; text-align:center; background:rgba(46,111,196,.12); color:var(--sky); border:1px solid rgba(46,111,196,.28); padding:.62rem; border-radius:.8rem; text-decoration:none; font-weight:600; font-size:.86rem; transition:all .3s; }
    .offre-btn:hover { background:var(--sky); color:white; border-color:var(--sky); }

    /* CONSEILS */
    #conseils { background:var(--navy); }
    .conseils-layout { display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; align-items:start; }
    .conseil-list { display:flex; flex-direction:column; gap:.6rem; }
    .conseil-item { display:flex; gap:.9rem; align-items:flex-start; padding:1.1rem 1.3rem; border-radius:1rem; border:1px solid var(--glass-border); background:var(--glass); cursor:pointer; transition:all .3s; }
    .conseil-item.active,.conseil-item:hover { border-color:rgba(46,111,196,.45); background:rgba(46,111,196,.07); }
    .conseil-item.active { border-left:3px solid var(--sky); }
    .conseil-icon { font-size:1.4rem; flex-shrink:0; }
    .conseil-ttl { font-weight:600; font-size:.92rem; margin-bottom:.15rem; }
    .conseil-txt { font-size:.82rem; color:var(--silver); line-height:1.45; }
    .conseil-detail { background:var(--glass); border:1px solid var(--glass-border); border-radius:1.4rem; padding:2.2rem; position:sticky; top:90px; }
    .detail-emoji { font-size:2.8rem; margin-bottom:.9rem; }
    .detail-title { font-family:'Cormorant Garamond',serif; font-size:1.7rem; font-weight:600; margin-bottom:.9rem; }
    .detail-body { color:var(--silver); line-height:1.7; font-size:.9rem; }
    .detail-body ul { padding-left:1.2rem; margin-top:.8rem; display:flex; flex-direction:column; gap:.4rem; }
    .detail-body li strong { color:var(--white); }

    /* COMPARATEUR */
    #comparateur { background:var(--night); }
    .comp-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .comp-card { border:1px solid var(--glass-border); border-radius:1.2rem; overflow:hidden; background:var(--glass); transition:transform .3s, border-color .3s; }
    .comp-card:hover { transform:translateY(-4px); border-color:rgba(46,111,196,.35); }
    .comp-card.featured { border-color:var(--gold); transform:scale(1.02); }
    .comp-top { padding:1.3rem; border-bottom:1px solid var(--glass-border); display:flex; align-items:center; gap:.8rem; }
    .comp-logo-emoji { font-size:1.7rem; }
    .comp-partner { font-weight:600; font-size:.95rem; }
    .comp-cat { font-size:.73rem; color:var(--silver); }
    .comp-badge-featured { margin-left:auto; background:var(--gold); color:var(--night); font-size:.66rem; font-weight:700; letter-spacing:.06em; padding:.22rem .65rem; border-radius:2rem; }
    .comp-body { padding:1.3rem; }
    .comp-feature { display:flex; align-items:center; gap:.6rem; font-size:.83rem; margin-bottom:.65rem; color:var(--silver); }
    .comp-feature .ok { color:#4ade80; }
    .comp-feature .ko { color:#f87171; }
    .comp-price-row { margin-top:1.1rem; padding-top:1.1rem; border-top:1px solid var(--glass-border); }
    .comp-commission { color:var(--gold); font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:600; }
    .comp-commission-l { font-size:.73rem; color:var(--silver); margin-top:.1rem; }
    .comp-join { display:block; text-align:center; margin-top:.9rem; background:var(--sky); color:white; border:none; cursor:pointer; font-family:'Outfit',sans-serif; font-weight:600; font-size:.85rem; padding:.62rem; border-radius:.8rem; text-decoration:none; transition:all .3s; }
    .comp-join:hover { background:var(--gold); color:var(--night); }
    .comp-card.featured .comp-join { background:var(--gold); color:var(--night); }
    .comp-card.featured .comp-join:hover { background:white; }

    /* TÉMOIGNAGES */
    #avis { background:var(--navy); }
    .temoignages { display:grid; grid-template-columns:repeat(auto-fill,minmax(270px,1fr)); gap:1.1rem; }
    .temo-card { background:var(--glass); border:1px solid var(--glass-border); border-radius:1.2rem; padding:1.7rem; transition:transform .3s; }
    .temo-card:hover { transform:translateY(-4px); }
    .temo-stars { color:var(--gold); font-size:.95rem; margin-bottom:.9rem; letter-spacing:.12em; }
    .temo-text { font-size:.86rem; color:var(--silver); line-height:1.6; font-style:italic; margin-bottom:1.1rem; }
    .temo-author { display:flex; align-items:center; gap:.75rem; }
    .temo-avatar { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.1rem; background:rgba(46,111,196,.2); }
    .temo-name { font-weight:600; font-size:.88rem; }
    .temo-dest { font-size:.73rem; color:var(--sky); }

    /* FAQ */
    #faq { background:var(--night); }
    .faq-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; max-width:860px; margin:0 auto; }
    .faq-item { border:1px solid var(--glass-border); border-radius:1rem; overflow:hidden; background:var(--glass); }
    .faq-q { width:100%; background:none; border:none; color:var(--white); cursor:pointer; font-family:'Outfit',sans-serif; font-size:.9rem; font-weight:500; padding:1.05rem 1.2rem; display:flex; justify-content:space-between; align-items:center; text-align:left; gap:1rem; transition:background .2s; }
    .faq-q:hover { background:rgba(255,255,255,.03); }
    .faq-q .arrow { flex-shrink:0; font-size:.75rem; transition:transform .3s; }
    .faq-item.open .arrow { transform:rotate(180deg); }
    .faq-a { max-height:0; overflow:hidden; transition:max-height .4s ease, padding .3s; font-size:.83rem; color:var(--silver); line-height:1.65; }
    .faq-item.open .faq-a { max-height:200px; padding:0 1.2rem 1.2rem; }

    /* NEWSLETTER */
    #newsletter { background:var(--navy); }
    .nl-box { max-width:620px; margin:0 auto; text-align:center; background:var(--glass); border:1px solid var(--glass-border); border-radius:2rem; padding:4rem 3rem; position:relative; overflow:hidden; }
    .nl-box::before { content:''; position:absolute; top:-80px; left:50%; transform:translateX(-50%); width:320px; height:320px; border-radius:50%; background:radial-gradient(circle,rgba(46,111,196,.1),transparent 70%); pointer-events:none; }
    .nl-icon { font-size:2.8rem; margin-bottom:1.1rem; display:block; }
    .nl-box .s-title { font-size:2.1rem; }
    .nl-box .s-sub { margin-inline:auto; margin-top:.7rem; margin-bottom:2rem; }
    .nl-form { display:flex; gap:.75rem; flex-wrap:wrap; justify-content:center; }
    .nl-input { flex:1; min-width:210px; background:rgba(255,255,255,.06); border:1px solid var(--glass-border); color:var(--white); font-family:'Outfit',sans-serif; font-size:.93rem; padding:.83rem 1.4rem; border-radius:2rem; outline:none; transition:border-color .3s; }
    .nl-input:focus { border-color:var(--sky); }
    .nl-input::placeholder { color:var(--silver); }
    .nl-submit { background:var(--sky); color:white; border:none; cursor:pointer; font-family:'Outfit',sans-serif; font-size:.93rem; font-weight:600; padding:.83rem 1.8rem; border-radius:2rem; transition:all .3s; }
    .nl-submit:hover { background:var(--gold); color:var(--night); transform:translateY(-2px); }

    /* FOOTER */
    footer { background:var(--night); border-top:1px solid var(--glass-border); padding:4rem 5vw 2rem; }
    .footer-top { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:3rem; margin-bottom:3rem; }
    .footer-about { font-size:.86rem; color:var(--silver); line-height:1.7; margin-top:.8rem; }
    .footer-col h5 { font-size:.7rem; letter-spacing:.12em; text-transform:uppercase; color:var(--sky); margin-bottom:1.1rem; }
    .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:.6rem; }
    .footer-col a { color:var(--silver); text-decoration:none; font-size:.86rem; transition:color .25s; }
    .footer-col a:hover { color:var(--white); }
    .footer-bottom { border-top:1px solid var(--glass-border); padding-top:2rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; font-size:.8rem; color:var(--silver); }
    .socials { display:flex; gap:.5rem; }
    .social-btn { width:32px; height:32px; border-radius:50%; background:var(--glass); border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center; font-size:.85rem; text-decoration:none; transition:background .25s, transform .2s; }
    .social-btn:hover { background:rgba(46,111,196,.2); transform:translateY(-2px); }

    /* REVEAL */
    .reveal { opacity:0; transform:translateY(22px); transition:opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }

    /* RESPONSIVE */
    @media(max-width:960px){
      nav{padding:0 1.5rem;} .nav-center{display:none;} .hero h1{font-size:3rem;} .float-cards{display:none;}
      .dest-grid{grid-template-columns:1fr 1fr;} .dest-card.large{grid-column:span 2;}
      .conseils-layout{grid-template-columns:1fr;} .conseil-detail{display:none;}
      .comp-grid{grid-template-columns:1fr;} .comp-card.featured{transform:none;}
      .faq-grid{grid-template-columns:1fr;} .footer-top{grid-template-columns:1fr 1fr;}
    }
    @media(max-width:600px){
      section{padding:4rem 1.5rem;} .dest-grid{grid-template-columns:1fr;} .dest-card.large{grid-column:span 1;}
      .hero-stats{gap:2rem;} footer{padding:3rem 1.5rem 1.5rem;} .footer-top{grid-template-columns:1fr;}
    }
  </style>
</head>
